# Velkor Vibe starter — environment variables
# Copy to .env.local for local dev; set the same three in Vercel (Project → Settings → Environment Variables).

# From Supabase → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# Service role key — SERVER ONLY. Never expose in client code; never commit.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Gate for the /pm dashboard in production: open /pm?key=THIS-VALUE
# Pick any long random string. In local dev the gate is off.
PM_KEY=CHOOSE-A-LONG-RANDOM-STRING
